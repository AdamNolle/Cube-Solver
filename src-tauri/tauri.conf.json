{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cube Solver",
  "version": "0.1.0",
  "identifier": "io.github.adamnolle.cubesolver",
  "build": {
    "frontendDist": "../web",
    "beforeDevCommand": {
      "script": "python3 tools/build-wasm.py",
      "cwd": "..",
      "wait": true
    },
    "beforeBuildCommand": {
      "script": "python3 tools/build-wasm.py",
      "cwd": ".."
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cube Solver — N×N Solver Studio",
        "width": 1380,
        "height": 900,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Replay-verified N×N cube solver studio",
    "longDescription": "Build random or custom 2×2–11×11 scrambles, solve from the visible sticker state, independently replay every accepted path, and explore truthful evolutionary-computing and reduction telemetry."
  }
}
